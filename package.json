{
  "name": "albania-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:packages\" \"npm run dev:web\" --names \"packages,web\" --prefix-colors \"blue,green\"",
    "dev:packages": "tsc --build --watch",
    "dev:web": "npm run dev --workspace=@albania/web",
    "dev:mobile": "cd apps/mobile/BookinAl && npm run start",
    "build": "npm run build --workspace=@albania/web",
    "build:web": "npm run build --workspace=@albania/web",
    "lint": "npm run lint --workspaces --if-present",
    "preview": "npm run preview --workspace=@albania/web",
    "supa": "supabase",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules",
    "typecheck": "tsc --build",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up",
    "docker:rebuild": "docker-compose build --no-cache && docker-compose up -d"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "supabase": "^2.72.8",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "react-phone-number-input": "^3.4.16"
  }
}
