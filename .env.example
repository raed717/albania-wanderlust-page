# Email Service Environment Configuration
# Copy this file to .env.local and fill in with your values

# ============================================================================
# Supabase Configuration (Frontend)
# ============================================================================

# Your Supabase project URL
# Find at: https://supabase.com → Your Project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anonymous key (public, safe to expose)
# Find at: https://supabase.com → Your Project → Settings → API
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# IMPORTANT: Backend Secrets (DO NOT EXPOSE TO FRONTEND)
# ============================================================================

# These are set in Supabase via CLI, NOT in .env files
# Set via: supabase secrets set RESEND_API_KEY "your_key_here"

# Your Resend API Key
# Get from: https://resend.com → API Keys
# Format: re_xxxxxxxxxxxxxxxxxx
# CLI: supabase secrets set RESEND_API_KEY "re_..."

# ============================================================================
# Optional: Email Configuration
# ============================================================================

# Email address to use as "from" (can be overridden per email)
# This should match a verified domain in Resend
# VITE_EMAIL_FROM=noreply@discover-albania.com

# Admin email for error notifications (if implementing alerts)
# VITE_EMAIL_ADMIN=admin@discover-albania.com

# Enable JWT verification for email endpoint (optional)
# VITE_EMAIL_REQUIRE_AUTH=false

# ============================================================================
# Instructions
# ============================================================================

# 1. Get Resend API key at https://resend.com
# 2. Set in Supabase: supabase secrets set RESEND_API_KEY "re_..."
# 3. Copy this file to .env.local
# 4. Fill in VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY
# 5. Start dev server: npm run dev

# ============================================================================
# Verifying Setup
# ============================================================================

# Check secrets are set:
# $ supabase secrets list

# Test email sending:
# $ curl -X POST http://127.0.0.1:54321/functions/v1/send-email \
#   -H "Content-Type: application/json" \
#   -d '{"to":"test@example.com","subject":"Test","html":"<h1>Test</h1>"}'
