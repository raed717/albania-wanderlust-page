# Email Service Environment Configuration
# Copy this file to .env.local and fill in with your values

# ============================================================================
# Supabase Configuration (Frontend)
# ============================================================================

# Your Supabase project URL
# Find at: https://supabase.com → Your Project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anonymous key (public, safe to expose)
# Find at: https://supabase.com → Your Project → Settings → API
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# Payment Configuration (Frontend - Safe to expose)
# ============================================================================

# PayPal Client ID (Sandbox for development, Live for production)
# Get from: https://developer.paypal.com → Dashboard → Apps & Credentials
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id_here

# Stripe Publishable Key (Sandbox/Test for development, Live for production)
# Get from: https://dashboard.stripe.com → Developers → API keys
# Use pk_test_... for sandbox, pk_live_... for production
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# ============================================================================
# IMPORTANT: Backend Secrets (DO NOT EXPOSE TO FRONTEND)
# ============================================================================

# These are set in Supabase via CLI, NOT in .env files
# Set via: supabase secrets set RESEND_API_KEY "your_key_here"

# Your Resend API Key
# Get from: https://resend.com → API Keys
# Format: re_xxxxxxxxxxxxxxxxxx
# CLI: supabase secrets set RESEND_API_KEY "re_..."

# PayPal Backend Secrets (set via Supabase CLI)
# CLI: supabase secrets set PAYPAL_CLIENT_ID "your_client_id"
# CLI: supabase secrets set PAYPAL_CLIENT_SECRET "your_client_secret"
# CLI: supabase secrets set PAYPAL_BASE_URL "https://api-m.sandbox.paypal.com"

# Stripe Backend Secrets (set via Supabase CLI)
# Get from: https://dashboard.stripe.com → Developers → API keys
# Use sk_test_... for sandbox, sk_live_... for production
# CLI: supabase secrets set STRIPE_SECRET_KEY "sk_test_..."
# CLI: supabase secrets set STRIPE_WEBHOOK_SECRET "whsec_..."
# Note: Webhook secret is obtained when creating webhook endpoint in Stripe Dashboard

# ============================================================================
# Optional: Email Configuration
# ============================================================================

# Email address to use as "from" (can be overridden per email)
# This should match a verified domain in Resend
# VITE_EMAIL_FROM=noreply@discover-albania.com

# Admin email for error notifications (if implementing alerts)
# VITE_EMAIL_ADMIN=admin@discover-albania.com

# Enable JWT verification for email endpoint (optional)
# VITE_EMAIL_REQUIRE_AUTH=false

# ============================================================================
# Instructions
# ============================================================================

# 1. Get Resend API key at https://resend.com
# 2. Set in Supabase: supabase secrets set RESEND_API_KEY "re_..."
# 3. Copy this file to .env.local
# 4. Fill in VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY
# 5. Start dev server: npm run dev

# ============================================================================
# Verifying Setup
# ============================================================================

# Check secrets are set:
# $ supabase secrets list

# Test email sending:
# $ curl -X POST http://127.0.0.1:54321/functions/v1/send-email \
#   -H "Content-Type: application/json" \
#   -d '{"to":"test@example.com","subject":"Test","html":"<h1>Test</h1>"}'
