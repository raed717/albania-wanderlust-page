{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "moduleDetection": "force",
    "noFallthroughCasesInSwitch": false,
    "noEmit": true
  },
  "include": [
    "apps/web/src",
    "packages/shared-types/src",
    "packages/api-client/src",
    "packages/hooks/src",
    "packages/utils/src"
  ]
}
